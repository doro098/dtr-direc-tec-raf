# =============================================================================
# dtr-direc-tec-raf — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# =============================================================================

# --- Tag-Mule Configuration ---
# URL to the Ollama LLM runtime (inside Docker network)
OLLAMA_URL=http://ollama:11434

# Path to the Tag-Mule config file inside the container
CONFIG_PATH=/app/config.yaml

# --- Ollama Models ---
# These are pre-loaded inside the container after startup:
#   docker compose exec ollama ollama pull qwen2.5:3b
#   docker compose exec ollama ollama pull nomic-embed-text
# Models persist in the ollama_data Docker volume.

# --- Tag-Mule Callback URL ---
# The callback URL that Tag-Mule posts enriched results to.
# This MUST be set in tag_mule/config.yaml under sources.tureparto.callback_url
# Default for Docker compose: http://cliente-tureparto:3001/webhook
# Default for host debugging: http://host.docker.internal:8089/webhook

# --- Tag-Mule Enrichment Settings (configurable in config.yaml) ---
# method: embedding
# provider: ollama
# model: nomic-embed-text
# max_tags: 3
# threshold: 0.6
# categories: pedido, consulta, reclamo, direccion, horario, precio, producto, cancelacion
